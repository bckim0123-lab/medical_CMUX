# Gemini (Google AI Studio)
GEMINI_API_KEY=

# 공공데이터포털 — HIRA(심평원) 병원 정보 서비스
# https://www.data.go.kr/data/15001698/openapi.do
HIRA_API_KEY=

# KOSIS Open API (통계청)
# https://kosis.kr/openapi/index/index.jsp
KOSIS_API_KEY=

# data.go.kr 통합 서비스키 (HIRA·기타 보건 API 공통)
DATA_GO_KR_KEY=

# 행정안전부 행정구역(읍면동) 경계 — 선택적
JUSO_API_KEY=

# Mock 모드 — 1이면 .json fixture 사용, 0이면 실 API 호출 시도
USE_MOCK=1
