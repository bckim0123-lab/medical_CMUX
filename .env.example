# Gemini (Google AI Studio)
GEMINI_API_KEY=

# ── 건강보험심사평가원(HIRA) — 공공데이터포털(data.go.kr) ─────────────
# 같은 계정의 서비스키여도 서비스별로 신청해야 활성화됩니다.
# 한 계정 한 키로 3개 서비스 다 쓰면 세 칸 모두 같은 값을 넣어도 됩니다.

# 1) 병원정보서비스 (병의원 목록·좌표·진료과)
#    https://www.data.go.kr/data/15001698/openapi.do
HIRA_HOSPITAL_INFO_KEY=

# 2) 의료기관별상세정보서비스 (장비·의사 수·진료시간 등 상세)
#    https://www.data.go.kr/data/15001699/openapi.do
HIRA_HOSPITAL_DETAIL_KEY=

# 3) 약국정보서비스 (약국 목록·좌표)
#    https://www.data.go.kr/data/15000563/openapi.do
HIRA_PHARMACY_INFO_KEY=

# ── 통계청 KOSIS Open API ─────────────────────────────────────────────
# https://kosis.kr/openapi/index/index.jsp
KOSIS_API_KEY=

# ── 행정안전부 행정구역(읍면동) 경계 — 선택적 ────────────────────────
JUSO_API_KEY=

# Mock 모드 — 1이면 data/mock/*.json fixture 사용, 0이면 실 API 호출 시도
USE_MOCK=1

# HIRA 진료기관 종별코드 (선택). 31=의원, 21=병원, 11=종합병원, 01=상급종합.
# 미설정 시 전체 종별 포함. 동네 접근성 분석에는 의원(31)만 권장.
HIRA_CL_CD=
